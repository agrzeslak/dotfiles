{
  "permissions": {
    "allow": [
      "Search",
      "Grep",
      "LS",
      "Read",
      "TodoRead",
      "TodoWrite",
      "WebSearch",
      "Edit",
      "MultiEdit",
      "Write",
      "Bash(find *)",
      "Bash(fd *)",
      "Bash(rg *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(npm run *)",
      "Bash(npx *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "model": "opus",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
