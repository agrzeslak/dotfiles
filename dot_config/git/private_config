[core]
	editor = nvim
	excludesFile = ~/.gitignore
	autocrlf = input
	eol = lf
	safecrlf = true

[ui "color"]
	ui = always

[color]
	ui = true

[merge]
	conflictStyle = zdiff3
	tool = nvim -d

[pull]
	ff = only

[push]
	default = simple

[diff]
	algorithm = histogram
	indentHeuristic = true

[help]
	autocorrect = prompt

[protocol]
	version = 2

[alias]
	c = commit
	s = status
	st = status
	lg = log --oneline
	last = log -1 HEAD
	f = push --force-with-lease
	# https://stackoverflow.com/a/11688523/472927
	ss = "!f() { git stash show stash^{/$*} -p; }; f"
	sa = "!f() { git stash apply stash^{/$*}; }; f"
	sl = stash list
